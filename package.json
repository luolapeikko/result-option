{
	"name": "@luolapeikko/result-option",
	"version": "2.2.1",
	"description": "Rust style Result for TypeScript/Javascript",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		"types": {
			"import": "./dist/index.d.mts",
			"require": "./dist/index.d.cts"
		},
		"import": "./dist/index.mjs",
		"require": "./dist/index.cjs",
		"default": "./dist/index.mjs"
	},
	"scripts": {
		"doc": "typedoc",
		"build": "tsdown src/index.mts --minify --sourcemap --format cjs,esm --dts --clean",
		"prepublishOnly": "npm run build",
		"test": "vitest test --typecheck --run --no-isolate --coverage",
		"pretest": "npm run build",
		"coverage": "vitest test --typecheck --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
		"lint": "oxlint",
		"validate": "tsgo --noEmit --project tsconfig.test.json"
	},
	"files": [
		"dist"
	],
	"repository": "github:luolapeikko/result-option",
	"keywords": [
		"typescript",
		"result",
		"rust"
	],
	"author": "mharj",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^24.10.9",
		"@typescript/native-preview": "7.0.0-dev.20260124.1",
		"@vitest/coverage-v8": "^4.0.18",
		"c8": "^10.1.3",
		"oxlint": "^1.41.0",
		"prettier": "^3.8.1",
		"source-map-support": "^0.5.21",
		"tsdown": "^0.20.1",
		"typedoc": "^0.28.16",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"unrs-resolver"
		]
	}
}
