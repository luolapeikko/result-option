{
	"name": "@luolapeikko/result-option",
	"version": "2.2.3",
	"description": "Rust style Result for TypeScript/Javascript",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"require": {
			"types": "./dist/index.d.cts",
			"default": "./dist/index.cjs"
		},
		"default": "./dist/index.mjs"
	},
	"scripts": {
		"docs": "typedoc",
		"build": "tsdown src/index.mts --minify --sourcemap --format cjs,esm --dts --clean -c tsconfig.build.json",
		"prepublishOnly": "npm run build",
		"test": "vitest test --typecheck --run --no-isolate --coverage",
		"pretest": "npm run build",
		"coverage": "vitest test --typecheck --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
		"lint": "oxlint",
		"validate": "tsgo --noEmit"
	},
	"files": [
		"dist"
	],
	"repository": "github:luolapeikko/result-option",
	"keywords": [
		"typescript",
		"result",
		"rust"
	],
	"author": "mharj",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^24.12.4",
		"@typescript/native-preview": "7.0.0-dev.20260518.1",
		"@vitest/coverage-v8": "^4.1.6",
		"c8": "^11.0.0",
		"oxlint": "^1.65.0",
		"oxlint-tsgolint": "^0.23.0",
		"prettier": "^3.8.3",
		"source-map-support": "^0.5.21",
		"tsdown": "^0.22.0",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"unrs-resolver"
		]
	}
}
