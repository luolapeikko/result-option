{
	"name": "@luolapeikko/result-option",
	"version": "2.2.2",
	"description": "Rust style Result for TypeScript/Javascript",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"require": {
			"types": "./dist/index.d.cts",
			"default": "./dist/index.cjs"
		},
		"default": "./dist/index.mjs"
	},
	"scripts": {
		"docs": "typedoc",
		"build": "tsdown src/index.mts --minify --sourcemap --format cjs,esm --dts --clean -c tsconfig.build.json",
		"prepublishOnly": "npm run build",
		"test": "vitest test --typecheck --run --no-isolate --coverage",
		"pretest": "npm run build",
		"coverage": "vitest test --typecheck --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
		"lint": "oxlint",
		"validate": "tsgo --noEmit"
	},
	"files": [
		"dist"
	],
	"repository": "github:luolapeikko/result-option",
	"keywords": [
		"typescript",
		"result",
		"rust"
	],
	"author": "mharj",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^24.12.2",
		"@typescript/native-preview": "7.0.0-dev.20260417.1",
		"@vitest/coverage-v8": "^4.1.4",
		"c8": "^10.1.3",
		"oxlint": "^1.60.0",
		"oxlint-tsgolint": "^0.21.1",
		"prettier": "^3.8.3",
		"source-map-support": "^0.5.21",
		"tsdown": "^0.21.9",
		"typedoc": "^0.28.19",
		"typescript": "^5.9.3",
		"vitest": "^4.1.4"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"unrs-resolver"
		]
	}
}
